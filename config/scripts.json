{
	"scripts": [
		{
			"id": "search-game",
			"name": "BUSCAR JUEGO",
			"description": "Busca un juego en múltiples fuentes",
			"icon": "gamepad-2",
			"color": "#9b59b6",
			"command": "python3 scripts/search_game.py",
			"parameters": [
				{
					"name": "game",
					"label": "Nombre del Juego",
					"type": "text",
					"required": true,
					"placeholder": "Introduzca nombre..."
				}
			],
			"timeout": 30
		},
		{
			"id": "system-update",
			"name": "ACTUALIZAR SISTEMA",
			"description": "Actualiza todos los paquetes del sistema",
			"icon": "refresh-cw",
			"color": "#2ecc71",
			"command": "apt update && apt upgrade -y",
			"parameters": [],
			"timeout": 300,
			"confirm": true
		},
		{
			"id": "docker-cleanup",
			"name": "LIMPIEZA DOCKER",
			"description": "Elimina imágenes y volúmenes de Docker sin uso",
			"icon": "trash-2",
			"color": "#e74c3c",
			"command": "docker system prune -f",
			"parameters": [],
			"timeout": 60,
			"confirm": true
		}
	]
}
